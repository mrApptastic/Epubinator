@page "/"
@using Epubinator.Client.Models
@using Epubinator.Client.Services
@using Epubinator.Client.Components
@inject EpubLibraryService LibraryService
@inject EpubReaderService ReaderService
@inject ReadingProgressService ProgressService
@inject ThemeService ThemeService
@inject IJSRuntime JS

<!-- Top Toolbar -->
<div class="top-toolbar">
	<!-- Hamburger -->
	<button class="hamburger-btn btn btn-link" data-bs-toggle="offcanvas"
			data-bs-target="#mainSidebar" aria-label="Open menu">
		<svg width="22" height="22" viewBox="0 0 22 22" fill="currentColor">
			<rect y="3"  width="22" height="2.5" rx="1.25"/>
			<rect y="10" width="22" height="2.5" rx="1.25"/>
			<rect y="17" width="22" height="2.5" rx="1.25"/>
		</svg>
	</button>

	<!-- Book title -->
	<span class="book-title-label">@(_currentBook?.Title ?? "Epubinator")</span>

	<!-- Chapter navigation -->
	@if (_currentBook is not null)
	{
		<div class="chapter-nav">
			<button class="btn btn-sm btn-link p-1 text-body" title="Previous chapter"
					disabled="@(_chapterCurrent <= 1 || _isLoading)"
					@onclick="GoPrevChapterAsync">
				<i class="fas fa-chevron-left"></i>
			</button>
			<span class="chapter-indicator">@_chapterCurrent / @_chapterTotal</span>
			<button class="btn btn-sm btn-link p-1 text-body" title="Next chapter"
					disabled="@(_chapterCurrent >= _chapterTotal || _isLoading)"
					@onclick="GoNextChapterAsync">
				<i class="fas fa-chevron-right"></i>
			</button>
		</div>
	}
</div>

<!-- Main content -->
@if (_isLoading)
{
	<div class="reader-scroll-container d-flex align-items-center justify-content-center">
		<div class="text-center">
			<div class="spinner-border" role="status"></div>
			<p class="mt-3 text-muted">Opening book...</p>
		</div>
	</div>
}
else if (_currentBook is not null)
{
	<ReaderView @ref="_readerView"
				BookId="@_currentBook.Id"
				InitialChapterIndex="@_initialChapter"
				InitialScrollPercent="@_initialScroll"
				OnChapterChanged="HandleChapterChanged" />
}
else
{
	<!-- Welcome screen -->
	<div class="welcome-screen">
		<div class="welcome-icon"><i class="fas fa-book-open"></i></div>
		<h1>Epubinator</h1>
		<p class="lead mb-4">Your private, offline epub reader.</p>
		<button class="btn btn-primary" data-bs-toggle="offcanvas" data-bs-target="#mainSidebar">
			<i class="fas fa-plus me-2"></i>Add your first book
		</button>
	</div>
}

	<!-- Sidebar -->
<SideMenu CurrentBookId="@_currentBook?.Id" OnBookSelected="SelectBookAsync" />

<!-- PWA update toast -->
<UpdatePrompt />

@code {
	private ReaderView? _readerView;

	private BookMetadata? _currentBook;
	private int _initialChapter;
	private double _initialScroll;

	private int _chapterCurrent = 1;
	private int _chapterTotal = 1;
	private bool _isLoading;

	// ── Lifecycle ─────────────────────────────────────────────────────────────

	protected override async Task OnInitializedAsync()
	{
		await ThemeService.InitialiseAsync();
		await LibraryService.InitialiseAsync();
	}

	// ── Book selection ────────────────────────────────────────────────────────

	private async Task SelectBookAsync(BookMetadata book)
	{
		_isLoading = true;
		StateHasChanged();

		try
		{
			var bytes = await LibraryService.GetBookBytesAsync(book.Id);
			if (bytes is null || bytes.Length == 0)
			{
				_isLoading = false;
				return;
			}

			await ReaderService.LoadBookAsync(bytes);

			var progress = await ProgressService.GetAsync(book.Id);
			_initialChapter = progress?.ChapterIndex ?? 0;
			_initialScroll  = progress?.ScrollPercent ?? 0;

			_currentBook    = book;
			_chapterCurrent = _initialChapter + 1;
			_chapterTotal   = ReaderService.ChapterCount;
		}
		finally
		{
			_isLoading = false;
		}
	}

	private void HandleChapterChanged((int Current, int Total) info)
	{
		_chapterCurrent = info.Current;
		_chapterTotal   = info.Total;
		InvokeAsync(StateHasChanged);
	}

	private async Task GoPrevChapterAsync()
	{
		if (_readerView is not null)
			await _readerView.GoToPreviousChapter();
	}

	private async Task GoNextChapterAsync()
	{
		if (_readerView is not null)
			await _readerView.GoToNextChapter();
	}
}
